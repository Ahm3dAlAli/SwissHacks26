# Copy to .env and fill in real values. NEVER commit .env with real seeds or keys.
# See docs/XLS65-DEVNET-INTEGRATION.md for a step-by-step setup guide.

# ── XRPL networks ────────────────────────────────────────────────
TESTNET_RPC_URL=wss://s.altnet.rippletest.net:51233
DEVNET_RPC_URL=wss://s.devnet.rippletest.net:51233

# ── Testnet: RLUSD issuer ─────────────────────────────────────────
RLUSD_ISSUER_TESTNET=

# ── Wallet seeds (Testnet) ────────────────────────────────────────
HQ_WALLET_SEED=
SUB_BRZ_WALLET_SEED=
SUB_DEU_WALLET_SEED=
SUB_SGP_WALLET_SEED=
VAULT_WALLET_SEED=
# Agent signs autonomous sweeps with its regular key (AG5). Master seed NEVER in agent runtime.
AGENT_WALLET_SEED=
AGENT_REGULAR_KEY_SEED=

# ── Wallet seeds (Devnet — XLS-65 vault) ─────────────────────────
HQ_WALLET_SEED_DEVNET=
VAULT_WALLET_SEED_DEVNET=
BROKER_WALLET_SEED_DEVNET=

# Addresses (informational — not read by the app, useful for debugging)
HQ_ADDRESS_DEVNET=
VAULT_ADDRESS_DEVNET=
BROKER_ADDRESS_DEVNET=

# ── XLS-65 XRP Vault (Devnet) ────────────────────────────────────
# The LedgerIndex printed by VaultCreate (from AffectedNodes[CreatedNode].LedgerIndex)
XRP_VAULT_ID_DEVNET=
VAULT_ID_DEVNET=
XRP_VAULT_SHARE_MPT_ID_DEVNET=

# ── XLS-65 RLUSD Vault (Devnet) ──────────────────────────────────
# IMPORTANT: RLUSD is a >3-char currency — must use the 40-char uppercase hex code.
# Derive it with: Buffer.from('RLUSD','ascii').toString('hex').toUpperCase().padEnd(40,'0')
# Result: 524C555344000000000000000000000000000000
RLUSD_CURRENCY_DEVNET=524C555344000000000000000000000000000000
# Issuer wallet for mock RLUSD on Devnet
RLUSD_ISSUER_DEVNET=
RLUSD_ISSUER_ADDRESS_DEVNET=
RLUSD_ISSUER_WALLET_SEED_DEVNET=
RLUSD_VAULT_ID_DEVNET=
RLUSD_VAULT_SHARE_MPT_ID_DEVNET=

# ── Live / Sim flags ─────────────────────────────────────────────
# Set DEVNET_LIVE=true once the devnet seeds and vault IDs are in place.
# Keep FORCE_SIM=true when running offline or in CI (no network calls made).
DEVNET_LIVE=false
LIVE_DEVNET=false
LIVE_TESTNET=false
FORCE_SIM=true

# ── AI (optional) ────────────────────────────────────────────────
# Without a key, both AI engines fall back to deterministic rule-based logic.
# Default provider: Groq (free, fast). Get a key at https://console.groq.com
AI_PROVIDER=openai
AI_API_BASE=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile

# ── App ──────────────────────────────────────────────────────────
BACKEND_PORT=3001
